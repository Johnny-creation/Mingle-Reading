# Mingle Reading MVP can run without external model credentials.
# When contributors want to wire persona-specific model endpoints,
# copy this file to `.env` and fill in only local development values.

# Optional app settings
# APP_HOST=127.0.0.1
# APP_PORT=8000

# Neutral / fallback reader
MUSE_NEUTRAL_API_KEY=""
MUSE_NEUTRAL_BASE_URL=""
MUSE_NEUTRAL_MODEL_NAME=""

# Memory embedding index.
# If omitted, the app can reuse MUSE_NEUTRAL_API_KEY,
# MUSE_NEUTRAL_BASE_URL, and MUSE_NEUTRAL_MODEL_NAME.
MINGLE_EMBEDDING_API_KEY=""
MINGLE_EMBEDDING_BASE_URL=""
MINGLE_EMBEDDING_MODEL_NAME=""

# Lu Xun lead-reader agent
LU_XUN_API_KEY=""
LU_XUN_BASE_URL=""
LU_XUN_MODEL_NAME=""

# Mark Twain lead-reader agent
MARK_TWAIN_API_KEY=""
MARK_TWAIN_BASE_URL=""
MARK_TWAIN_MODEL_NAME=""

# Zhang Ailing lead-reader agent
ZHANG_AILING_API_KEY=""
ZHANG_AILING_BASE_URL=""
ZHANG_AILING_MODEL_NAME=""
